---
// IMPORTER
import Prose from '../components/Prose.astro'
import Layout from '../layouts/Layout.astro'
import TagCloud from '../components/TagCloud.astro'
import ListNotes from '../components/ListNotes.astro'

import { sortCollection } from '../utils/posts'

// GET ALL NOTES
const allNotes = await sortCollection('NotProject')
---

<Layout>
	<div class="px-5 pt-10 lg:px-10">
		<header>
			<!-- SLIDER CATEGORIES -->
			<TagCloud/>
			<Prose>
				<h1>Sedang Mencari Resep?</h1>
				<p>
					Pernah nggak sih kalian bertanya-tanya, kenapa nasi goreng di warung pinggir jalan itu
					bisa seenak itu? 🤔 Aku sudah mencoba berbagai resep dari seluruh penjuru dunia—dari dapur
					rumah sampai dapur YouTube—tapi tetap saja rasanya belum nendang!
				</p>
				<p>
					Apakah ini hasil latihan bertahun-tahun? Atau… mungkinkah ada campur tangan makhluk halus?
					👻 Entahlah. Tapi satu yang pasti: pencarian ini belum selesai!
				</p>
			</Prose>
			<!-- SEARCH -->
		</header>

		<main class="mt-14">
			<ListNotes items={allNotes}>
		</main>
	</div>
</Layout>
