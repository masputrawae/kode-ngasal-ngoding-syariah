---
interface MenuItem {
	label: string
	url: string
	icon?: string
}

import { Icon } from 'astro-icon/components'

const { items } = Astro.props
---

<nav>
	{
		items.map((item: MenuItem) => {
			const { pathname } = Astro.url
			const urlActive = item.url === pathname || (item.url !== '/' && pathname.startsWith(item.url))

			const className = `flex items-center gap-3 px-4 py-2 text-sm text-shadow-sm text-shadow-black hover:text-neutral-50 font-semibold transition-all duration-300 ${urlActive ? 'text-white rounded-md bg-neutral-800 border border-neutral-700 shadow-sm shadow-black/50' : 'text-neutral-400'}`
			return (
				<a href={item.url} class={className}>
					<Icon name={item.icon} title={item.label} role="img" class="size-5" />
					{item.label}
				</a>
			)
		})
	}
</nav>
