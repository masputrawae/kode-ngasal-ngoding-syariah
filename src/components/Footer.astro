---
import { SITE_PARAMS } from '../siteConfig'

const title = SITE_PARAMS.title
const newYear = new Date().getFullYear()
---

<footer
	class="m-auto flex w-full flex-col items-center px-5 mt-10 py-10 border-t border-t-neutral-700 text-xs md:flex-row md:justify-between lg:px-10"
>
	<p>
		© {newYear} · {title} · All rights reserved. | <a href="/disclaimer/">Disclaimer</a>
	</p>
	<p>
		Made with ❤️ using <a href="https://astro.build/" target="_blank" rel="noopener noreferrer"
			>{Astro.generator}</a
		>
	</p>
</footer>
