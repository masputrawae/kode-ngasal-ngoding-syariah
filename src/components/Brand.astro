---
import { SITE_CONFIG } from '../SiteConfig'
import { Image } from 'astro:assets'
---

<figure class="group flex cursor-pointer items-center gap-2" onclick="window.location.href='/'">
	<picture
		class="block size-14 overflow-hidden rounded-full border-2 border-neutral-800 shadow-md shadow-black transition-shadow duration-300 group-hover:shadow-sm"
	>
		<Image
			src={SITE_CONFIG?.logo || ''}
			alt={SITE_CONFIG?.author || ''}
			width={56}
			height={56}
      format={'webp'}
      loading={`eager`}
      layout='constrained'
			class="size-14 transition-transform duration-300 group-hover:scale-110"
		/>
	</picture>
	<figcaption class="flex flex-col">
		<strong
			class="text-lg text-white transition-colors duration-300 text-shadow-black text-shadow-sm group-hover:text-amber-500"
			>{SITE_CONFIG.author}</strong
		>
		<em
			class="text-sm text-neutral-400 not-italic transition-colors duration-300 text-shadow-black text-shadow-sm group-hover:text-white"
			>{SITE_CONFIG.tagline}</em
		>
	</figcaption>
</figure>
